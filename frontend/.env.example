# Прокси Vite (dev и preview) → бэкенд, если не задан VITE_API_BASE
BACKEND_URL=http://localhost:8000

# Прямой URL бэкенда в браузере (рекомендуется при HTTP 404 на /api без прокси).
# Должен совпадать с адресом Go (PORT в backend/.env), например http://localhost:8000
# После добавления перезапустите npm run dev (Vite подхватывает .env при старте).
VITE_API_BASE=http://localhost:8000
