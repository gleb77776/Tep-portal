# Настройки LDAP (как в телефонном справочнике)
# Скопируйте в .env и заполните

LDAP_SERVER=tep-m.ru
LDAP_DOMAIN=TEP-M
LDAP_USER=Batyanovskiy_help
LDAP_PASSWORD=VLrx5siGo4

# Базовый DN для поиска (поиск по всему домену)
LDAP_BASE_DN=DC=tep-m,DC=ru

# Как в DEBUG=True в твоём другом проекте:
# пользовательские OU (разделяй ';' чтобы сузить выдачу и не тащить лишнее из AD)
LDAP_SEARCH_BASES=OU=Теплоэлектропроект,DC=tep-m,DC=ru;OU=Теплоэлектропроект Краснодар,DC=tep-m,DC=ru;OU=Теплоэлектропроект Волгоград,DC=tep-m,DC=ru;OU=Теплоэлектропроект Казань,DC=tep-m,DC=ru;OU=Теплоэлектропроект Кемерово,DC=tep-m,DC=ru;OU=Управление комплексного проектирования,OU=Теплоэлектропроект,DC=tep-m,DC=ru

# Фильтры поиска
LDAP_USER_SEARCH_FILTER=(objectClass=User)
LDAP_OU_SEARCH_FILTER=(objectClass=organizationalUnit)

# Как в Kanboard/phonebook: показывать только тех, у кого заполнен телефон.
# Отключить можно, установив LDAP_REQUIRE_TELEPHONE_NUMBER=false
LDAP_REQUIRE_TELEPHONE_NUMBER=true
LDAP_USER_PHONE_ATTRIBUTE=telephoneNumber

# Пользователь по умолчанию (если не передан в запросе)
AD_DEFAULT_USER=BatyanovskiyGV
# Первый администратор, пока в хранилище ролей нет записей (PostgreSQL или JSON).
BOOTSTRAP_ADMIN_USER=BatyanovskiyGV

# Роли пользователей: PostgreSQL (рекомендуется). Если не задано — используется data/user_roles.json.
# Пример: postgres://user:pass@localhost:5432/tep_portal?sslmode=disable
# Дублирующее имя переменной: POSTGRES_DSN
# DATABASE_URL=
# При первом старте с пустой таблицей роли подтягиваются из JSON. Чтобы отключить: SKIP_JSON_ROLES_IMPORT=1
#
# При подключённом PostgreSQL дополнительно создаются analytics_* и ref_technical_glossary (зеркало JSON + справочник 500 терминов — требования ВКР по таблицам/записям). API портала по-прежнему читает JSON/файлы.
# Отключить синхронизацию и посев: SKIP_PORTAL_PG_ANALYTICS=1

# Роль «Документация»: scoped-проекты (архив) и динамический раздел СРО — slug из реестра site_sections (по умолчанию arkhiv и sro).
# DOCUMENTATION_SCOPED_PROJECTS_SLUG=arkhiv
# DOCUMENTATION_DYNAMIC_DOCS_SLUG=sro

# Порт HTTP бэкенда (по умолчанию 8000).
# Если при go run видите «bind: Only one usage...» — порт занят: закройте старый процесс или смените PORT.
# Windows: netstat -ano | findstr :8000  затем taskkill /PID <номер> /F
PORT=8000

# Абсолютный путь к frontend/public (ролик главной /home-hero.mov). Если Go не находит файл сам — задайте вручную.
# FRONTEND_PUBLIC_DIR=D:\Диплом\Project-TepPortal\frontend\public

# Папка с файлами раздела «Охрана труда, ГО и ЧС» (по умолчанию data/ot_go_chs относительно рабочей директории бэкенда).
# OT_DOCS_PATH=

# Папка с файлами раздела «КЭПР» (по умолчанию data/kepr).
# KEPR_DOCS_PATH=

# Папки разделов «Бланки» и «Записи с программ обучения» (по умолчанию data/forms и data/training).
# FORMS_DOCS_PATH=
# TRAINING_DOCS_PATH=

# JSON со ссылками карточек главной (IT, TEP-WIKI, СКУД, СПРУТ). По умолчанию data/section_card_links.json
# SECTION_CARD_LINKS_PATH=

# JSON с меню раздела «Лицензии, программы». По умолчанию data/licenses_links.json
# LICENSES_LINKS_PATH=

# Реестр разделов портала (главная, «Все разделы», динамические /s/:slug). По умолчанию data/site_sections.json
# SITE_SECTIONS_PATH=
